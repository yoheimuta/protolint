{
  "extends": "@tsconfig/node20/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    "noUncheckedIndexedAccess": true,

    "moduleDetection": "force",

    "rootDir": "./",
    "types": ["node"],
  },
  "include": [
    "**/*.js",
    "**/*.cjs",
    "**/*.mjs",
    "**/*.json"
  ],
  "exclude": [
    "node_modules"
  ]
}
